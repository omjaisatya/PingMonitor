MONGO_URL=mongodb://localhost:27017/pingMonitor
PORT=3006
# JWT
JWT_SECRET=scretCodeJWT
JWT_REFRESH_SECRET=refreshCodeJWT
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

NODE_ENV=development
FRONTEND_URL=http://localhost:5173  //vite port
# RESEND
RESEND_API_KEY=api_key
SENDER_EMAIL=mail@domain

# Distributed multi-region monitoring
ENABLE_DISTRIBUTED_MONITORING=false
REDIS_URL=redis://localhost:6379
WORKER_NODE_TOKEN=4f6f2f5e8d1a7c3b9e2d4f8a1b6c7d9e5f2a8b3c1d7e9f4a6b8c2d1e5f7a9c3
MONITOR_REGIONS=us,europe,asia,australia
# Set only on regional worker processes: us | europe | asia | australia
MONITOR_NODE_REGION=us
WORKER_CONCURRENCY=10
IS_DEMO_MODE=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUDNAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_APIKEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_APISECRET
