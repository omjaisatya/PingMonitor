{
  "name": "com.pingmonitor.sp",
  "version": "0.0.4",
  "description": "pingmonitor is monitoring url checking if server is down",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "worker:region": "node src/workers/regionalWorker.js",
    "deploy:test": "cross-env NODE_ENV=test node server.js",
    "db:seed": "node src/scripts/runSeed.js",
    "postinstall": "npx playwright install chromium"
  },
  "keywords": [
    "saas",
    "domain",
    "check",
    "url",
    "broken"
  ],
  "author": "Satya Prakash",
  "license": "ISC",
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.65.1",
    "playwright": "^1.49.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "resend": "^6.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  }
